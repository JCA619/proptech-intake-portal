rules_version = '2';

// Firestore security rules for the PropTech Intake Portal.
//
// Model (Option A — create-only public access):
//   - Anyone (the public, unauthenticated) may CREATE a lead by submitting the form.
//   - NOBODY may read, update, or delete leads from the client/browser.
//   - To view submissions, open the Firebase Console -> Firestore Database -> 'leads'.
//
// This is the safe default for a static (GitHub Pages) site with no server:
// applicants' names, emails, phones, and addresses are never readable by the public.
//
// NOTE: The in-app Admin Dashboard (#/admin) will NOT show real leads under these
// rules — its read is denied and it falls back to local mock data. That is intended.
// If you later add Firebase Auth, change `allow read` to:
//     allow read: if request.auth != null;

service cloud.firestore {
  match /databases/{database}/documents {

    match /leads/{leadId} {
      // Public submissions allowed.
      allow create: if true;

      // No public reading or modifying.
      allow read, update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
